{
  "name": "liora-lang",
  "description": "LioraLang is a desktop app for learning languages with spaced repetition and flashcards.",
  "author": "Mark Storchovyi markstorchovyi@gmail.com",
  "homepage": "https://github.com/rorimark/LioraLang",
  "private": true,
  "version": "0.2.1",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite --mode desktop --host --port 5175 --strictPort",
    "dev:web": "vite --mode web --host --port 5175 --strictPort",
    "setup:web": "pnpm install --no-optional --ignore-scripts",
    "setup:desktop": "pnpm install",
    "dev:electron": "wait-on tcp:5175 && VITE_DEV_SERVER_URL=http://localhost:5175 electron .",
    "rebuild:native": "npm_config_runtime=electron npm_config_target=40.6.1 npm_config_disturl=https://electronjs.org/headers npm_config_build_from_source=true pnpm rebuild better-sqlite3",
    "build": "pnpm build:desktop",
    "build:desktop": "vite build --mode desktop",
    "build:web": "vite build --mode web",
    "icons:all": "node electron/scripts/build-icons.mjs --target all",
    "icons:mac": "node electron/scripts/build-icons.mjs --target mac",
    "icons:win": "node electron/scripts/build-icons.mjs --target win",
    "dist:test": "pnpm build:desktop && electron-builder --mac dmg --arm64 --publish never && electron-builder --win nsis --x64 --publish never && pnpm rebuild:native",
    "dist:test:mac": "pnpm build:desktop && electron-builder --mac dmg --arm64 --publish never && pnpm rebuild:native",
    "dist:test:win": "pnpm build:desktop && electron-builder --win nsis --x64 --publish never && pnpm rebuild:native",
    "check:persistence": "node electron/scripts/run-persistence-check.cjs",
    "check:boundaries": "bash scripts/check-no-electron-imports.sh",
    "lint": "eslint .",
    "preview": "pnpm preview:web",
    "preview:web": "pnpm build:web && vite preview --host --port 4175 --strictPort"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@feature-sliced/eslint-config": "^0.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.4.1",
    "electron": "40.6.1",
    "electron-builder": "^26.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "better-sqlite3",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.lioralang.app",
    "productName": "LioraLang",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/electron{,/**/*}",
      "!node_modules/electron-builder{,/**/*}",
      "!node_modules/.pnpm/electron@*",
      "!node_modules/.pnpm/electron@*/**",
      "!node_modules/.pnpm/electron-builder@*",
      "!node_modules/.pnpm/electron-builder@*/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js",
      "optionalDependencies": {
        "better-sqlite3": "^12.4.1"
      }
    },
    "asar": true,
    "fileAssociations": [
      {
        "ext": [
          "lioradeck"
        ],
        "name": "LioraLang Deck Package",
        "description": "LioraLang importable deck package",
        "role": "Editor"
      }
    ],
    "mac": {
      "icon": "electron/assets/icon@2x.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  }
}
