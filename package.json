{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:electron\"",
    "dev:web": "vite --host --port 5175 --strictPort",
    "dev:electron": "wait-on tcp:5175 && VITE_DEV_SERVER_URL=http://localhost:5175 electron .",
    "rebuild:native": "npm_config_runtime=electron npm_config_target=40.6.1 npm_config_disturl=https://electronjs.org/headers npm_config_build_from_source=true pnpm rebuild better-sqlite3",
    "build": "vite build",
    "dist:test": "pnpm build && electron-builder --mac dmg --arm64 --publish never && electron-builder --win nsis --x64 --publish never",
    "dist:test:mac": "pnpm build && electron-builder --mac dmg --arm64 --publish never",
    "dist:test:win": "pnpm build && electron-builder --win nsis --x64 --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@feature-sliced/eslint-config": "^0.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "40.6.1",
    "electron-builder": "^26.0.12",
    "eslint": "^10.0.2",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "better-sqlite3",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.lioralang.app",
    "productName": "LioraLang",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": true,
    "mac": {
      "icon": "electron/assets/icon@2x.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
